# Sourced by scripts/build.sh
# Alioth build is layered: kona-perf base + sm8250-common overlay + alioth overlay.
# The merge_config.sh helper handles overlay application.
DEFCONFIG_BASE="vendor/kona-perf_defconfig"
DEFCONFIG_OVERLAYS=(
  "vendor/xiaomi/sm8250-common.config"
  "vendor/xiaomi/alioth.config"
)
