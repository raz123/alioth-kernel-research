# zram + zswap + swap support overlay for alioth (SM8250 / 4.19)
# lz4 is the best speed/ratio tradeoff for ARM64 Android (NEON-optimized)

# --- Core infrastructure ---
CONFIG_SWAP=y
CONFIG_FRONTSWAP=y

# --- zram: compressed RAM block device (primary swap) ---
CONFIG_ZRAM=y
CONFIG_ZSMALLOC=y
CONFIG_PGTABLE_MAPPING=y

# --- zswap: compressed cache in front of swap ---
CONFIG_ZSWAP=y
CONFIG_ZPOOL=y
CONFIG_Z3FOLD=y

# --- Crypto (compression algorithms) ---
CONFIG_CRYPTO_LZ4=y
CONFIG_CRYPTO_ZSTD=y
