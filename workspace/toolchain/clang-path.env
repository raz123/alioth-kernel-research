# Sourced by scripts/build.sh
# Using AOSP clang-r584948 (Android (14488419, +pgo, +bolt, +lto, +mlgo) LLVM 22).
# Stock kernel was built with r563880c (LLVM 21). r584948 is the closest newer
# AOSP clang available in current prebuilts/clang HEAD; it has Android-specific
# kernel patches that upstream Ubuntu clang lacks (BTI, MTE, kernel CFI hooks).
#
# First attempt with system clang-21 (Ubuntu) compiled OK but produced a kernel
# that hung at boot — confirmed a clang miscompilation issue (vermagic + config
# were identical to stock, only compiler differed). Switching to AOSP clang.
CLANG_PATH="/home/ltlly/Code/kernel_research/workspace/toolchain/clang-aosp/clang-r584948/bin/clang"
CLANG_DIR="/home/ltlly/Code/kernel_research/workspace/toolchain/clang-aosp/clang-r584948/bin"
